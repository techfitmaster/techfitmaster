BEGIN:VCALENDAR
VERSION:2.0
PRODID:-//Albert 健身计划//CN
CALSCALE:GREGORIAN
METHOD:PUBLISH
X-WR-CALNAME:Albert 减脂训练计划
X-WR-TIMEZONE:Asia/Shanghai
X-WR-CALDESC:190斤→150斤 家居训练计划

BEGIN:VEVENT
DTSTART:20260209T190000
DTEND:20260209T200000
RRULE:FREQ=WEEKLY;BYDAY=MO;COUNT=26
SUMMARY:💪 上肢+核心训练
DESCRIPTION:俯卧撑 4×15-20\nPike俯卧撑 4×12\n引体向上 4×8-12\n臂屈伸 4×12\n平板支撑 4×60秒\n卷腹 4×20\n\n结束：30分钟HIIT或跳绳
LOCATION:家
STATUS:CONFIRMED
BEGIN:VALARM
TRIGGER:-PT30M
ACTION:DISPLAY
DESCRIPTION:30分钟后开始上肢训练！
END:VALARM
END:VEVENT

BEGIN:VEVENT
DTSTART:20260210T190000
DTEND:20260210T200000
RRULE:FREQ=WEEKLY;BYDAY=TU;COUNT=26
SUMMARY:🦵 下肢+爆发力训练
DESCRIPTION:深蹲 5×20\n保加利亚分腿蹲 4×15(每腿)\n深蹲跳 4×15\n箭步蹲 4×15(每腿)\n臀桥 4×20\n提踵 4×30\n\n结束：15分钟高抬腿
LOCATION:家
STATUS:CONFIRMED
BEGIN:VALARM
TRIGGER:-PT30M
ACTION:DISPLAY
DESCRIPTION:30分钟后开始下肢训练！
END:VALARM
END:VEVENT

